{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AjCaptcha": {
    "Type": "default",
    "CacheType": "Memory",
    "WaterMarkEnabled": true,
    "WaterMark": "veichi",
    "WaterFont": "WenQuanZhengHei.ttf",
    "WaterMarkColor": "#FFFFFF",
    "WaterMarkOpacity": 0.7,
    "WaterMarkFontSize": 18,
    "WaterMarkOffsetX": 12,
    "WaterMarkOffsetY": 10,
    "FontType": "WenQuanZhengHei.ttf",
    "SlipOffset": 5,
    "AesStatus": true,
    "InterferenceOptions": 2,
    "CacheNumber": 1000,
    "TimingClear": 180,
    "ReqFrequencyLimitEnable": false,
    "ReqGetLockLimit": 5,
    "ReqGetLockSeconds": 360,
    "ReqGetMinuteLimit": 30,
    "ReqCheckMinuteLimit": 30,
    "ReqVerifyMinuteLimit": 30,
    "FontStyle": 1,
    "FontSize": 25,
    "ClickWordCount": 4,
    "I18nEnabled": true,
    "DefaultCulture": "zh-CN"
  }
}
